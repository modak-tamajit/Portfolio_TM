# Gemini API Key (Required for Talk to Tamajit)
GEMINI_API_KEY=your_gemini_api_key

# Upstash Redis setup (for chatbot rate limiting - optional but recommended)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Vercel API Integration for Analytics Dashboard
VERCEL_ACCESS_TOKEN=your_vercel_access_token
VERCEL_PROJECT_ID=your_vercel_project_id

# Simple password for the /dashboard route
NEXT_PUBLIC_DASHBOARD_PASSWORD=hireme
